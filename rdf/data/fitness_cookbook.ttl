@prefix fc: <http://fitnesscookbook.com/ontology#> .
@prefix fcd: <http://fitnesscookbook.com/data/> .
@prefix fcp: <http://fitnesscookbook.com/person/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==========================================
# PERSONS (Authors) - Namespace Schema 1
# ==========================================

fcp:Zendaya a fc:Person ;
    fc:name "Zendaya" ;
    fc:createdRecipe fcd:rec_001 .

fcp:ChrisHemsworth a fc:Person ;
    fc:name "Chris Hemsworth" ;
    fc:createdRecipe fcd:rec_002 .

fcp:HaileyBieber a fc:Person ;
    fc:name "Hailey Bieber" ;
    fc:createdRecipe fcd:rec_003 .

fcp:SerenaWilliams a fc:Person ;
    fc:name "Serena Williams" ;
    fc:createdRecipe fcd:rec_004 .

# ==========================================
# INGREDIENTS - Namespace Schema 2
# ==========================================

fcd:ing_1 a fc:Ingredient ;
    fc:name "Egg Whites" ;
    fc:category "base" ;
    fc:usedIn fcd:rec_001 .

fcd:ing_2 a fc:Ingredient ;
    fc:name "Oats" ;
    fc:category "base" ;
    fc:usedIn fcd:rec_001 .

fcd:ing_4 a fc:Ingredient ;
    fc:name "Salmon" ;
    fc:category "protein" ;
    fc:usedIn fcd:rec_002 .

fcd:ing_5 a fc:Ingredient ;
    fc:name "Avocado" ;
    fc:category "veg" ;
    fc:usedIn fcd:rec_003 .

fcd:ing_7 a fc:Ingredient ;
    fc:name "Quinoa" ;
    fc:category "base" ;
    fc:usedIn fcd:rec_004 .

# ==========================================
# RECIPES - Namespace Schema 2
# ==========================================

fcd:rec_001 a fc:Recipe ;
    fc:title "Zendaya's Protein Blueberry Pancakes" ;
    fc:author fcp:Zendaya ;
    fc:difficulty "medium" ;
    fc:category "breakfast" ;
    fc:calories "350"^^xsd:integer ;
    fc:prepTime "10"^^xsd:integer ;
    fc:description "A light, camera-ready breakfast with balanced carbs and protein." ;
    fc:usesIngredient fcd:ing_1, fcd:ing_2 .

fcd:rec_002 a fc:Recipe ;
    fc:title "Chris Hemsworth's Lemon Herb Baked Salmon" ;
    fc:author fcp:ChrisHemsworth ;
    fc:difficulty "easy" ;
    fc:category "dinner" ;
    fc:calories "420"^^xsd:integer ;
    fc:prepTime "5"^^xsd:integer ;
    # Intentionally missing description to test OPTIONAL queries
    fc:usesIngredient fcd:ing_4 .

fcd:rec_003 a fc:Recipe ;
    fc:title "Hailey Bieber's Avocado Toast with Poached Egg" ;
    fc:author fcp:HaileyBieber ;
    fc:difficulty "easy" ;
    fc:category "snack" ;
    fc:calories "280"^^xsd:integer ;
    fc:prepTime "5"^^xsd:integer ;
    fc:description "A balanced brunch favorite with healthy fats and quality protein." ;
    fc:usesIngredient fcd:ing_5 .

fcd:rec_004 a fc:Recipe ;
    fc:title "Serena Williams' Quinoa Power Bowl" ;
    fc:author fcp:SerenaWilliams ;
    fc:difficulty "hard" ;
    fc:category "lunch" ;
    fc:calories "520"^^xsd:integer ;
    fc:prepTime "15"^^xsd:integer ;
    fc:usesIngredient fcd:ing_7 .